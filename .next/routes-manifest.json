    },
    {
      "page": "/legal/terminos",
      "regex": "^/legal/terminos(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/legal/terminos(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/moderacion",
      "regex": "^/moderacion(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/moderacion(?:/)?$"
    },
    {
      "page": "/perfil",
      "regex": "^/perfil(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/perfil(?:/)?$"
    },
    {
      "page": "/prompts",
      "regex": "^/prompts(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/prompts(?:/)?$"
    },
    {
      "page": "/quienes-somos",
      "regex": "^/quienes\\-somos(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/quienes\\-somos(?:/)?$"
    },
    {
