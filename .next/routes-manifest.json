      "namedRegex": "^/auth/confirm(?:/)?$"
    },
    {
      "page": "/biblioteca",
      "regex": "^/biblioteca(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/biblioteca(?:/)?$"
    },
    {
      "page": "/confirmar-cuenta",
      "regex": "^/confirmar\\-cuenta(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/confirmar\\-cuenta(?:/)?$"
    },
    {
      "page": "/desarrollador",
      "regex": "^/desarrollador(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/desarrollador(?:/)?$"
    },
    {
      "page": "/legal/privacidad",
      "regex": "^/legal/privacidad(?:/)?$",
