0:00.000Z","updatedAt":"2026-06-12T08:00:00.000Z","version":2,"limitations":"Debe adaptarse a protocolos locales.","misuseRisks":"No sustituye recomendaciones clinicas individualizadas.","references":["Programas PROA SEIMC"],"variables":[{"id":"prompt-005-var-1","promptId":"prompt-005","name":"escenario clinico","token":"[escenario clinico]","type":"textarea","options":[],"required":true,"order":0,"helpText":"Describe el escenario de forma general y anonima."},{"id":"prompt-005-var-2","promptId":"prompt-005","name":"tipo de centro","token":"[tipo de centro]","type":"select","options":["hospital terciario","hospital comarcal","atencion primaria","centro sociosanitario"],"required":true,"order":1,"helpText":"Selecciona una opcion."}],"license":"CC BY 4.0"}}],["$","$La","prompt-001",{"prompt":{"id":"prompt-001","slug":"lectura-critica-articulo-clinico","title":"Lectura critica de articulo clinico","summary":"Estructura una lectura critica de un articulo de infecciosas o microbiologia con foco en validez, resultados y aplicabilidad.","content":"Actua como [rol profesional] y realiza una lectura critica de un articulo sobre [tema]. Evalua: 1) pregunta de investigacion, 2) diseno, 3) poblacion, 4) intervencion o exposicion, 5) comparador, 6) desenlaces, 7) sesgos principales, 8) magnitud del efecto, 9) validez externa y 10) aplicabilidad a [contexto asistencial]. Devuelve una tabla breve y una conclusion final para [publico objetivo]. No inventes datos que no aparezcan en el texto proporcionado.","objective":"Ayudar a preparar journal club y sesiones de lectura critica.","context":"El usuario debe pegar el resumen o el texto del articulo sin datos personales.","author":"$7:props:children:1:props:children:0:props:prompt:author","category":"Lectura critica","secondaryCategories":["Investigacion","Docencia"],"tools":["ChatGPT","Claude","Elicit"],"recommendedModel":"ChatGPT 5.5","intelligenceLevel":"Alto","language":"Español","bestLanguage":"Español","difficulty":"intermedio","tags":["journal club","evidencia","sesion clinica"],"reviewStatus":"approved","experimental":false,"validatedByGiant":true,"giantQualityScore":5,"likes":46,"favorites":32,"copies":121,"templateUses":88,"timeSavedMinutes":35,"publishedAt":"2026-06-01T08:00:00.000Z","updatedAt":"2026-06-10T08:00:00.000Z","version":2,"limitations":"Necesita que el usuario aporte informacion del articulo; no sustituye lectura metodologica experta.","misuseRisks":"Puede producir conclusiones demasiado seguras si el usuario pega solo fragmentos.","references":["CASP","CONSORT","STROBE"],"variables":[{"id":"prompt-001-var-1","promptId":"prompt-001","name":"rol profesional","token":"[rol profesional]","type":"select","options":["infectologo/a","microbiologo/a","residente","investigador/a"],"required":true,"order":0,"helpText":"Selecciona una opcion."},{"id":"prompt-001-var-2","promptId":"prompt-001","name":"tema","token":"[tema]","type":"text","options":[],"required":true,"order":1},{"id":"prompt-001-var-3","promptId":"prompt-001","name":"contexto asistencial","token":"[contexto asistencial]","type":"select","options":["hospital terciario","hospital comarcal","atencion primaria","laboratorio clinico"],"required":true,"order":2,"helpText":"Selecciona una opcion."},{"id":"prompt-001-var-4","promptId":"prompt-001","name":"publico objetivo","token":"[publico objetivo]","type":"select","options":["residentes","adjuntos","comite PROA","equipo de laboratorio"],"required":true,"order":3,"helpText":"Selecciona una opcion."}],"license":"CC BY 4.0"}}],"$Lb"]}]]}]
