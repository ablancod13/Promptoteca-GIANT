":"La Promptoteca GIANT nace como una herramienta de finalidad científica, docente y profesional destinada a facilitar que miembros de la Sociedad Española de Enfermedades Infecciosas y Microbiología Clínica —SEIMC— y profesionales vinculados al ámbito de las enfermedades infecciosas, la microbiología clínica y disciplinas afines puedan utilizar de forma más eficiente, crítica y estructurada herramientas de inteligencia artificial."}],null,["$","p","6",{"children":"La plataforma permite consultar, compartir y reutilizar prompts elaborados por personas autoras individuales, con el objetivo de favorecer el aprendizaje, la alfabetización digital, la mejora de competencias profesionales y la exploración de usos potenciales de la inteligencia artificial en contextos docentes, científicos, organizativos o asistenciales."}],null,"$L7",null,"$L8",null,"$L9",null,"$La",null,"$Lb",null,"$Lc",null,"$Ld",null,"$Le",null,"$Lf",null,"$L10","$L11","$L12","$L13","$L14","$L15",null,"$L16",null,"$L17",null,"$L18",null,"$L19",null,"$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23","$L24",null,"$L25",null,"$L26",null,"$L27",null,"$L28",null,"$L29","$L2a","$L2b","$L2c","$L2d","$L2e","$L2f",null,"$L30",null,"$L31",null,"$L32",null,"$L33",null,"$L34","$L35","$L36","$L37","$L38","$L39","$L3a","$L3b",null,"$L3c",null,"$L3d",null,"$L3e",null,"$L3f","$L40","$L41","$L42","$L43","$L44","$L45","$L46","$L47","$L48","$L49","$L4a",null,"$L4b",null,"$L4c",null,"$L4d",null,"$L4e",null,"$L4f","$L50","$L51","$L52","$L53","$L54",null,"$L55",null,"$L56",null,"$L57",null,"$L58",null,"$L59","$L5a","$L5b","$L5c","$L5d","$L5e","$L5f","$L60","$L61","$L62",null,"$L63",null,"$L64",null,"$L65",null,"$L66","$L67","$L68","$L69","$L6a","$L6b","$L6c","$L6d","$L6e","$L6f",null,"$L70",null,"$L71",null,"$L72","$L73","$L74","$L75","$L76",null,"$L77",null,"$L78",null,"$L79",null,"$L7a",null,"$L7b",null,"$L7c",null,"$L7d",null,"$L7e",null,"$L7f",null,"$L80",null,"$L81",null,"$L82",null,"$L83",null,"$L84",null,"$L85",null,"$L86",null,"$L87",null,"$L88",null,"$L89",null,"$L8a",null,"$L8b",null,"$L8c",null,"$L8d",null,"$L8e",null,"$L8f",null,"$L90",null,"$L91",null,"$L92",null,"$L93",null,"$L94",null,"$L95","$L96","$L97","$L98","$L99","$L9a","$L9b","$L9c","$L9d","$L9e",null,"$L9f",null,"$La0",null,"$La1",null,"$La2",null,"$La3",null,"$La4",null,"$La5",null,"$La6",null,"$La7",null,"$La8","$La9","$Laa","$Lab",null]}]}],null,"$Lac"]}],{},null,false,null]},null,false,"$@ad"]},null,false,"$@ad"]},null,false,null],"$Lae",false]],"m":"$undefined","G":["$af",["$Lb0"]],"S":true,"h":null,"s":"$undefined","l":"$undefined","p":"$undefined","d":"$undefined","b":"so4XuTs9xqGkKXXLVKxyj"}
