7:["$","h2","10",{"children":"2. Naturaleza de la plataforma"}]
8:["$","p","12",{"children":"La Promptoteca GIANT es una plataforma de consulta, publicación y reutilización de prompts elaborados por personas autoras individuales."}]
9:["$","p","14",{"children":"Los contenidos publicados tienen finalidad docente, científica, divulgativa, organizativa o experimental. No constituyen una herramienta clínica, diagnóstica, terapéutica, asistencial, legal, administrativa ni de toma automatizada de decisiones."}]
a:["$","p","16",{"children":"La plataforma no sustituye el juicio profesional, la revisión crítica, la validación científica, la supervisión humana ni el cumplimiento de las normas legales, deontológicas o institucionales aplicables."}]
b:["$","h2","18",{"children":"3. Registro de usuarios"}]
c:["$","p","20",{"children":"Para acceder a determinadas funcionalidades de la plataforma, la persona usuaria deberá registrarse proporcionando información veraz, actualizada y suficiente."}]
d:["$","p","22",{"children":"La persona usuaria se compromete a:"}]
e:["$","p","24",{"className":"legal-item","children":"a. Facilitar datos reales, exactos y actualizados."}]
f:["$","p","25",{"className":"legal-item","children":"b. No registrarse utilizando identidades falsas o de terceros."}]
10:["$","p","26",{"className":"legal-item","children":"c. Custodiar adecuadamente sus credenciales de acceso."}]
11:["$","p","27",{"className":"legal-item","children":"d. No compartir su cuenta con otras personas."}]
12:["$","p","28",{"className":"legal-item","children":"e. Comunicar cualquier acceso no autorizado o sospecha de uso indebido."}]
13:["$","p","29",{"className":"legal-item","children":"f. Mantener actualizada la información relevante de su perfil."}]
14:["$","p","31",{"children":"La plataforma podrá rechazar, suspender o cancelar registros cuando existan indicios de falsedad, uso indebido, suplantación, incumplimiento de estos términos o riesgo para la seguridad de la plataforma."}]
15:["$","h2","33",{"children":"4. Validación profesional y número de colegiado"}]
16:["$","p","35",{"children":"La plataforma podrá solicitar el número de colegiado, especialidad, centro de trabajo, afiliación profesional u otros datos equivalentes con la finalidad de verificar que la persona usuaria pertenece al ámbito profesional, sanitario, científico, docente o institucional al que se dirige la Promptoteca GIANT."}]
17:["$","p","37",{"children":"El número de colegiado podrá utilizarse exclusivamente para fines de validación profesional, control de acceso, prevención de usos indebidos, trazabilidad interna y verificación de pertenencia al colectivo profesional correspondiente."}]
18:["$","p","39",{"children":"La plataforma no utilizará el número de colegiado para finalidades incompatibles con estos términos ni lo publicará de forma abierta salvo consentimiento expreso de la persona usuaria o exigencia legal aplicable."}]
19:["$","h2","41",{"children":"5. Obligaciones generales de la persona usuaria"}]
1a:["$","p","43",{"children":"Toda persona usuaria se compromete a utilizar la plataforma de forma diligente, ética, responsable, respetuosa y conforme a la legislación vigente."}]
1b:["$","p","45",{"children":"En particular, la persona usuaria se compromete a:"}]
1c:["$","p","47",{"className":"legal-item","children":"a. Respetar estos términos de uso."}]
1d:["$","p","48",{"className":"legal-item","children":"b. Respetar la Política de privacidad de la plataforma."}]
1e:["$","p","49",{"className":"legal-item","children":"c. Respetar los códigos de conducta profesionales, científicos y deontológicos aplicables."}]
1f:["$","p","50",{"className":"legal-item","children":"d. Actuar con buena fe y respeto hacia otras personas usuarias, autores, moderadores, desarrolladores y entidades vinculadas."}]
20:["$","p","51",{"className":"legal-item","children":"e. No publicar contenido ilícito, ofensivo, discriminatorio, vejatorio, fraudulento, engañoso o contrario a la ética profesional."}]
21:["$","p","52",{"className":"legal-item","children":"f. No utilizar la plataforma para fines abusivos, comerciales no autorizados, fraudulentos, maliciosos o ajenos a su finalidad científica y docente."}]
22:["$","p","53",{"className":"legal-item","children":"g. No introducir datos personales de pacientes ni información que permita su identificación directa o indirecta."}]
23:["$","p","54",{"className":"legal-item","children":"h. No comprometer la seguridad, integridad, disponibilidad o funcionamiento técnico de la plataforma."}]
24:["$","p","55",{"className":"legal-item","children":"i. No realizar extracción masiva, scraping, automatización abusiva o explotación no autorizada de contenidos."}]
25:["$","p","56",{"className":"legal-item","children":"j. Revisar críticamente cualquier prompt o resultado generado mediante herramientas de inteligencia artificial."}]
26:["$","h2","58",{"children":"6. Código de conducta"}]
27:["$","p","60",{"children":"La Promptoteca GIANT se rige por principios de respeto, profesionalidad, colaboración, rigor, transparencia, aprendizaje compartido y uso responsable de la inteligencia artificial."}]
28:["$","p","62",{"children":"No se permitirá ninguna conducta que pueda afectar negativamente a la comunidad, a la integridad científica de la plataforma, a la reputación de otras personas usuarias o al correcto funcionamiento del proyecto."}]
29:["$","p","64",{"children":"Se consideran contrarias al código de conducta, entre otras:"}]
2a:["$","p","66",{"className":"legal-item","children":"a. Faltas de respeto, insultos, acoso, amenazas o ataques personales."}]
2b:["$","p","67",{"className":"legal-item","children":"b. Comentarios discriminatorios por razón de sexo, género, edad, origen, religión, orientación sexual, discapacidad, situación profesional o cualquier otra condición personal o social."}]
2c:["$","p","68",{"className":"legal-item","children":"c. Publicación de contenido deliberadamente falso, engañoso o malicioso."}]
2d:["$","p","69",{"className":"legal-item","children":"d. Manipulación de puntuaciones, rankings, valoraciones, métricas o sistemas de reputación."}]
2e:["$","p","70",{"className":"legal-item","children":"e. Uso de identidades falsas o suplantación de terceros."}]
2f:["$","p","71",{"className":"legal-item","children":"f. Publicación de contenido con datos personales de pacientes o información confidencial."}]
30:["$","p","72",{"className":"legal-item","children":"g. Publicación de prompts que promuevan actuaciones ilícitas, inseguras o contrarias a la ética profesional."}]
31:["$","p","73",{"className":"legal-item","children":"h. Uso de la plataforma para desprestigiar a personas, instituciones, sociedades científicas, grupos profesionales o entidades concretas."}]
32:["$","p","74",{"className":"legal-item","children":"i. Uso de la plataforma con finalidad publicitaria, promocional o comercial no autorizada."}]
33:["$","p","75",{"className":"legal-item","children":"j. Cualquier conducta que, a juicio razonado de la moderación o del desarrollador, perjudique a la comunidad o contravenga la finalidad de la plataforma."}]
34:["$","h2","77",{"children":"7. Publicación de prompts"}]
35:["$","p","79",{"children":"La persona usuaria que publique prompts en la Promptoteca GIANT declara y garantiza que:"}]
36:["$","p","81",{"className":"legal-item","children":"a. Es autora del contenido o dispone de los derechos necesarios para publicarlo."}]
37:["$","p","82",{"className":"legal-item","children":"b. El contenido no infringe derechos de propiedad intelectual o industrial de terceros."}]
38:["$","p","83",{"className":"legal-item","children":"c. El contenido no contiene datos personales de pacientes ni información confidencial."}]
39:["$","p","84",{"className":"legal-item","children":"d. El contenido no contiene información ilícita, discriminatoria, ofensiva, fraudulenta o contraria a la ética profesional."}]
3a:["$","p","85",{"className":"legal-item","children":"e. El contenido no debe interpretarse como recomendación oficial de SEIMC ni de ningún grupo de trabajo."}]
3b:["$","p","86",{"className":"legal-item","children":"f. El contenido refleja exclusivamente su opinión, experiencia, criterio o propuesta individual."}]
3c:["$","p","87",{"className":"legal-item","children":"g. Asume la responsabilidad sobre la exactitud, originalidad, licitud y adecuación del prompt publicado."}]
3d:["$","p","89",{"children":"La plataforma podrá revisar, clasificar, destacar, ocultar, modificar, despublicar o eliminar prompts cuando lo considere necesario por razones de calidad, seguridad, moderación, cumplimiento normativo, protección de datos, propiedad intelectual o adecuación a la finalidad de la plataforma."}]
3e:["$","p","91",{"children":"La publicación, revisión, validación, verificación o visibilidad de un prompt en la plataforma no implica aval científico, validación metodológica, recomendación clínica, respaldo institucional ni adhesión de GIANT, SEIMC o sus grupos de trabajo al contenido publicado."}]
3f:["$","h2","93",{"children":"8. Licencia de publicación de prompts: CC BY 4.0"}]
40:["$","p","95",{"children":"Al publicar un prompt en la Promptoteca GIANT, la persona autora acepta que dicho contenido se publique bajo licencia Creative Commons Attribution 4.0 International —CC BY 4.0—, salvo que la plataforma indique expresamente otra licencia compatible."}]
41:["$","p","97",{"children":"Esta licencia permite a otras personas copiar, compartir, distribuir, reutilizar, adaptar, transformar y construir a partir del prompt, incluso para fines amplios, siempre que se reconozca adecuadamente la autoría y la fuente."}]
42:["$","p","99",{"children":"La atribución deberá incluir, siempre que sea razonablemente posible:"}]
43:["$","p","101",{"className":"legal-item","children":"a. El nombre público, alias profesional o identificador elegido por la persona autora."}]
44:["$","p","102",{"className":"legal-item","children":"b. La referencia a la Promptoteca GIANT como plataforma de publicación original."}]
45:["$","p","103",{"className":"legal-item","children":"c. La mención de la licencia CC BY 4.0."}]
46:["$","p","104",{"className":"legal-item","children":"d. La indicación de si se han realizado modificaciones o adaptaciones."}]
47:["$","p","106",{"children":"La persona autora acepta que la licencia CC BY 4.0 es una licencia de reutilización amplia y que la retirada posterior del prompt de la plataforma no afectará necesariamente a los usos legítimos realizados por terceros mientras el contenido estuvo publicado bajo dicha licencia."}]
48:["$","p","108",{"children":"La persona autora conserva sus derechos morales de autoría en los términos previstos por la legislación aplicable."}]
49:["$","h2","110",{"children":"9. Identidad pública y atribución de autoría"}]
4a:["$","p","112",{"children":"La plataforma procurará proteger la identidad real de las personas usuarias y permitirá, cuando sea técnicamente posible, que la atribución pública de los prompts se realice mediante nombre público, alias profesional, identificador de usuario o fórmula equivalente."}]
4b:["$","p","114",{"children":"La persona usuaria entiende que, al publicar contenidos bajo licencia CC BY 4.0, será necesario algún tipo de atribución pública para permitir la correcta reutilización del contenido."}]
4c:["$","p","116",{"children":"La plataforma no publicará datos personales innecesarios para la atribución, salvo consentimiento expreso de la persona usuaria o exigencia legal aplicable."}]
4d:["$","h2","118",{"children":"10. Prohibición de datos de pacientes"}]
4e:["$","p","120",{"children":"Queda estrictamente prohibido introducir, publicar, almacenar, copiar o procesar en la plataforma datos personales de pacientes o información que pueda permitir su identificación directa o indirecta."}]
4f:["$","p","122",{"children":"Esta prohibición incluye, entre otros:"}]
50:["$","p","124",{"className":"legal-item","children":"a. Nombre y apellidos."}]
51:["$","p","125",{"className":"legal-item","children":"b. Iniciales identificativas."}]
52:["$","p","126",{"className":"legal-item","children":"c. Número de historia clínica."}]
53:["$","p","127",{"className":"legal-item","children":"d. DNI, NIE, pasaporte u otros identificadores."}]
54:["$","p","128",{"className":"legal-item","children":"e. Fechas exactas clínicamente trazables."}]
55:["$","p","129",{"className":"legal-item","children":"f. Imágenes clínicas identificables."}]
56:["$","p","130",{"className":"legal-item","children":"g. Informes clínicos, microbiológicos, radiológicos o genómicos asociados a una persona identificada o identificable."}]
57:["$","p","131",{"className":"legal-item","children":"h. Casos raros o singulares que permitan reidentificación."}]
58:["$","p","132",{"className":"legal-item","children":"i. Cualquier combinación de variables que pueda hacer reconocible a una persona."}]
59:["$","p","134",{"children":"La responsabilidad por la introducción indebida de datos de pacientes corresponde exclusivamente a la persona usuaria que realice dicha acción."}]
5a:["$","p","136",{"children":"La plataforma podrá eliminar sin previo aviso cualquier contenido que contenga o pueda contener datos personales, información sanitaria identificable o material clínico sensible."}]
5b:["$","h2","138",{"children":"11. Moderación de contenidos y conducta"}]
5c:["$","p","140",{"children":"La plataforma podrá disponer de personas moderadoras, administradoras o desarrolladoras encargadas de revisar contenidos, resolver incidencias, atender reportes, valorar conductas inapropiadas y aplicar medidas correctoras."}]
5d:["$","p","142",{"children":"La moderación podrá actuar de oficio o a partir de comunicaciones de otras personas usuarias."}]
5e:["$","p","144",{"children":"La persona usuaria acepta que las decisiones de moderación podrán incluir:"}]
5f:["$","p","146",{"className":"legal-item","children":"a. Advertencias o llamados de atención."}]
60:["$","p","147",{"className":"legal-item","children":"b. Solicitud de modificación o retirada de contenido."}]
61:["$","p","148",{"className":"legal-item","children":"c. Ocultación temporal de prompts, comentarios o interacciones."}]
62:["$","p","149",{"className":"legal-item","children":"d. Despublicación definitiva de contenidos."}]
63:["$","p","150",{"className":"legal-item","children":"e. Limitación de funcionalidades."}]
64:["$","p","151",{"className":"legal-item","children":"f. Modificación, anulación o corrección de puntuaciones, métricas, rankings o KPIs."}]
65:["$","p","152",{"className":"legal-item","children":"g. Suspensión temporal de la cuenta."}]
66:["$","p","153",{"className":"legal-item","children":"h. Expulsión o baneo permanente de la plataforma."}]
67:["$","p","155",{"children":"Las decisiones de moderación se adoptarán atendiendo a la gravedad de la conducta, reiteración, intencionalidad, impacto en terceros, riesgo legal, riesgo reputacional, afectación a la comunidad y necesidad de preservar el correcto funcionamiento de la plataforma."}]
68:["$","h2","157",{"children":"12. Régimen de avisos, faltas y sanciones"}]
69:["$","p","159",{"children":"Las conductas contrarias a estos términos podrán clasificarse, orientativamente, como faltas leves, moderadas o graves."}]
6a:["$","h3","161",{"children":"12.1. Faltas leves"}]
6b:["$","p","163",{"children":"Podrán considerarse faltas leves:"}]
6c:["$","p","165",{"className":"legal-item","children":"a. Incumplimientos menores de normas de formato."}]
6d:["$","p","166",{"className":"legal-item","children":"b. Publicación de contenido duplicado o poco adecuado tras advertencia."}]
6e:["$","p","167",{"className":"legal-item","children":"c. Uso inadecuado no intencional de categorías, etiquetas o descripciones."}]
6f:["$","p","168",{"className":"legal-item","children":"d. Comentarios poco constructivos sin gravedad suficiente."}]
70:["$","p","169",{"className":"legal-item","children":"e. Conductas corregibles sin daño relevante para terceros o para la plataforma."}]
71:["$","p","171",{"children":"Las faltas leves podrán dar lugar a aviso, llamado de atención, solicitud de corrección, ocultación temporal del contenido o limitación puntual de funcionalidades."}]
72:["$","h3","173",{"children":"12.2. Faltas moderadas"}]
73:["$","p","175",{"children":"Podrán considerarse faltas moderadas:"}]
74:["$","p","177",{"className":"legal-item","children":"a. Reiteración de faltas leves."}]
75:["$","p","178",{"className":"legal-item","children":"b. Desatención de avisos previos de moderadores o desarrolladores."}]
76:["$","p","179",{"className":"legal-item","children":"c. Publicación de contenido engañoso, inadecuado o contrario a la finalidad de la plataforma."}]
77:["$","p","180",{"className":"legal-item","children":"d. Conductas que afecten al clima de respeto de la comunidad."}]
78:["$","p","181",{"className":"legal-item","children":"e. Intentos de manipulación menor de puntuaciones, rankings, valoraciones o métricas."}]
79:["$","p","182",{"className":"legal-item","children":"f. Uso promocional o comercial no autorizado."}]
7a:["$","p","184",{"children":"Las faltas moderadas podrán dar lugar a advertencia formal, modificación o eliminación de contenido, modificación de puntuaciones, suspensión temporal, pérdida de funcionalidades o revisión reforzada de publicaciones futuras."}]
7b:["$","h3","186",{"children":"12.3. Faltas graves"}]
7c:["$","p","188",{"children":"Podrán considerarse faltas graves:"}]
7d:["$","p","190",{"className":"legal-item","children":"a. Introducción o publicación de datos personales de pacientes."}]
7e:["$","p","191",{"className":"legal-item","children":"b. Suplantación de identidad."}]
7f:["$","p","192",{"className":"legal-item","children":"c. Acoso, amenazas, insultos graves o conducta discriminatoria."}]
80:["$","p","193",{"className":"legal-item","children":"d. Manipulación deliberada de puntuaciones, rankings, KPIs o sistemas internos."}]
81:["$","p","194",{"className":"legal-item","children":"e. Ataques técnicos, intentos de acceso no autorizado o alteración del funcionamiento de la plataforma."}]
82:["$","p","195",{"className":"legal-item","children":"f. Publicación de contenido ilícito, malicioso, fraudulento o gravemente contrario a la ética profesional."}]
83:["$","p","196",{"className":"legal-item","children":"g. Infracción grave de derechos de propiedad intelectual."}]
84:["$","p","197",{"className":"legal-item","children":"h. Uso de la plataforma para fines delictivos, dañinos o manifiestamente abusivos."}]
85:["$","p","198",{"className":"legal-item","children":"i. Reiteración de faltas moderadas tras advertencia."}]
86:["$","p","199",{"className":"legal-item","children":"j. Cualquier conducta que genere riesgo legal, reputacional, técnico, científico o ético relevante para la plataforma, sus usuarios, GIANT, SEIMC o terceros."}]
87:["$","p","201",{"children":"Las faltas graves podrán dar lugar a suspensión inmediata, baneo temporal o permanente, eliminación de contenidos, anulación de puntuaciones, bloqueo de funcionalidades, comunicación a las entidades competentes cuando proceda y adopción de medidas legales si fueran necesarias."}]
88:["$","h2","203",{"children":"13. Modificación de puntuaciones, rankings y KPIs"}]
89:["$","p","205",{"children":"La plataforma podrá disponer de sistemas de puntuación, rankings, métricas de actividad, indicadores de uso, KPIs, valoraciones, favoritos, interacciones o reconocimiento de contribuciones."}]
8a:["$","p","207",{"children":"La persona usuaria acepta que dichas puntuaciones y métricas podrán ser revisadas, corregidas, modificadas, anuladas o eliminadas cuando existan indicios de:"}]
8b:["$","p","209",{"className":"legal-item","children":"a. Conductas contrarias a estos términos."}]
8c:["$","p","210",{"className":"legal-item","children":"b. Manipulación o uso abusivo de la plataforma."}]
8d:["$","p","211",{"className":"legal-item","children":"c. Errores técnicos."}]
8e:["$","p","212",{"className":"legal-item","children":"d. Duplicidad de cuentas."}]
8f:["$","p","213",{"className":"legal-item","children":"e. Automatización indebida."}]
90:["$","p","214",{"className":"legal-item","children":"f. Actividad fraudulenta."}]
91:["$","p","215",{"className":"legal-item","children":"g. Incumplimiento del código de conducta."}]
92:["$","p","216",{"className":"legal-item","children":"h. Necesidad de preservar la equidad, integridad o finalidad científica de la plataforma."}]
93:["$","p","218",{"children":"La modificación de puntuaciones o KPIs no generará derecho a compensación, indemnización o reclamación frente a la plataforma, sus desarrolladores, moderadores, administradores, GIANT, SEIMC o entidades vinculadas."}]
94:["$","h2","220",{"children":"14. Uso de datos, métricas y KPIs con fines científicos"}]
95:["$","p","222",{"children":"La persona usuaria acepta que los datos derivados de su actividad en la plataforma, incluyendo métricas de uso, patrones agregados de interacción, KPIs, número de prompts publicados, consultas, copias, valoraciones, categorías, participación, evolución temporal y otros indicadores funcionales, puedan ser utilizados con fines de investigación científica, análisis docente, mejora de la plataforma, evaluación de impacto, publicaciones académicas, comunicaciones científicas, informes internos o actividades de innovación."}]
96:["$","p","224",{"children":"Dicho uso se realizará procurando proteger la identidad de las personas usuarias mediante anonimización, agregación, seudonimización u otras medidas razonables de minimización de riesgos."}]
97:["$","p","226",{"children":"Los resultados se presentarán preferentemente de forma agregada, sin identificación directa de personas usuarias individuales."}]
98:["$","p","228",{"children":"Cuando el uso de datos personales identificables, seudonimizados o especialmente sensibles requiera consentimiento específico, evaluación ética, informe del delegado de protección de datos, aprobación institucional u otra garantía adicional, la plataforma procurará aplicar las medidas exigidas por la normativa aplicable."}]
99:["$","p","230",{"children":"La persona usuaria podrá ejercer los derechos que le correspondan conforme a la normativa de protección de datos."}]
9a:["$","h2","232",{"children":"15. Comunicaciones de la plataforma"}]
9b:["$","p","234",{"children":"La persona usuaria acepta recibir comunicaciones necesarias para el funcionamiento de la plataforma, incluyendo avisos de registro, seguridad, cambios en los términos, incidencias técnicas, moderación, gestión de cuenta, recuperación de contraseña, notificaciones funcionales y comunicaciones estrictamente relacionadas con el servicio."}]
9c:["$","p","236",{"children":"Asimismo, la persona usuaria podrá aceptar de forma separada recibir comunicaciones informativas, docentes, científicas, comerciales o promocionales de GIANT, sus desarrolladores o entidades vinculadas."}]
9d:["$","p","238",{"children":"Las comunicaciones comerciales o promocionales deberán ser identificables como tales y la persona usuaria podrá retirar su consentimiento o darse de baja mediante un procedimiento sencillo y gratuito."}]
9e:["$","p","240",{"children":"La aceptación de comunicaciones comerciales no será condición necesaria para registrarse o utilizar las funcionalidades esenciales de la plataforma, salvo que se indique expresamente y de forma justificada conforme a la normativa aplicable."}]
9f:["$","h2","242",{"children":"16. No venta comercial de datos a la industria farmacéutica o terceros comerciales"}]
a0:["$","p","244",{"children":"La plataforma no venderá datos personales identificativos de las personas usuarias a la industria farmacéutica, empresas de productos sanitarios, empresas tecnológicas, aseguradoras, consultoras, entidades comerciales ni terceros con finalidad comercial."}]
a1:["$","p","246",{"children":"La plataforma podrá elaborar análisis agregados, anonimizados o estadísticos sobre el uso de la plataforma para fines científicos, docentes, estratégicos, de mejora, transparencia, comunicación institucional o sostenibilidad del proyecto, siempre procurando evitar la identificación de personas usuarias individuales."}]
a2:["$","p","248",{"children":"Cualquier colaboración externa que pudiera implicar tratamiento de datos personales deberá ajustarse a la normativa aplicable y a la política de privacidad de la plataforma."}]
a3:["$","h2","250",{"children":"17. Seguridad, confidencialidad y limitación de responsabilidad ante incidentes"}]
a4:["$","p","252",{"children":"La plataforma aplicará medidas técnicas y organizativas razonables para proteger la información de las personas usuarias, prevenir accesos no autorizados y reducir el riesgo de pérdida, alteración, exposición o manipulación de datos."}]
a5:["$","p","254",{"children":"No obstante, ningún sistema digital puede garantizar una seguridad absoluta."}]
a6:["$","p","256",{"children":"La persona usuaria acepta que, en la máxima medida permitida por la ley, la plataforma, sus desarrolladores, administradores, moderadores, colaboradores, GIANT, SEIMC y entidades vinculadas no serán responsables de daños, perjuicios, pérdida de información, exposición de datos, accesos no autorizados, hackeos, ataques informáticos, errores graves, vulnerabilidades técnicas, manipulación malintencionada por terceros o incidentes de seguridad ajenos al control razonable de la plataforma."}]
a7:["$","p","258",{"children":"La plataforma se compromete a actuar de buena fe y a adoptar medidas razonables para prevenir, detectar, mitigar y comunicar los incidentes de seguridad cuando proceda conforme a la normativa aplicable."}]
a8:["$","h2","260",{"children":"18. Propiedad intelectual de la plataforma"}]
a9:["$","p","262",{"children":"La estructura, diseño, marca, nombre, logotipo, bases de datos, funcionalidades, código, interfaz, organización de contenidos, sistema de clasificación, elementos gráficos y demás componentes propios de la plataforma pertenecen a sus titulares o cuentan con las autorizaciones correspondientes."}]
aa:["$","p","264",{"children":"La aceptación de estos términos no otorga a la persona usuaria derechos sobre la marca, denominación, diseño, software, estructura o elementos propios de la plataforma, salvo los derechos estrictamente necesarios para su uso ordinario conforme a estos términos."}]
ab:["$","h2","266",{"children":"19. Responsabilidad sobre herramientas externas de inteligencia artificial"}]
ac:["$","p","268",{"children":"La persona usuaria podrá copiar prompts de la plataforma y utilizarlos en herramientas externas de inteligencia artificial, buscadores, asistentes conversacionales u otros servicios de terceros."}]
ad:["$","p","270",{"children":"La persona usuaria será la única responsable de revisar las condiciones de uso, política de privacidad, configuración de confidencialidad, limitaciones, riesgos y consecuencias del uso de dichas herramientas externas."}]
ae:["$","p","272",{"children":"La plataforma no se responsabiliza de los resultados generados por sistemas externos, de sus errores, alucinaciones, sesgos, omisiones, reutilización de datos, entrenamiento de modelos, transferencias internacionales, conservación de información ni consecuencias derivadas de su uso."}]
af:["$","h2","274",{"children":"20. Suspensión, baja y eliminación de cuenta"}]
b0:["$","p","276",{"children":"La persona usuaria podrá solicitar la baja de su cuenta conforme al procedimiento habilitado por la plataforma."}]
b1:["$","p","278",{"children":"La baja de la cuenta podrá implicar la desactivación del perfil y la eliminación o anonimización de determinados datos, sin perjuicio de la conservación de aquellos registros que deban mantenerse por razones legales, técnicas, de seguridad, auditoría, investigación, defensa frente a reclamaciones o cumplimiento de estos términos."}]
b2:["$","p","280",{"children":"La eliminación de la cuenta no afectará necesariamente a:"}]
b3:["$","p","282",{"className":"legal-item","children":"a. Los usos legítimos previos de prompts publicados bajo licencia CC BY 4.0."}]
b4:["$","p","283",{"className":"legal-item","children":"b. Datos agregados o anonimizados ya incorporados a análisis, informes, publicaciones o resultados científicos."}]
b5:["$","p","284",{"className":"legal-item","children":"c. Registros mínimos necesarios para prevenir abuso, fraude, suplantación o incumplimientos."}]
b6:["$","p","285",{"className":"legal-item","children":"d. Evidencias necesarias para atender reclamaciones o responsabilidades legales."}]
b7:["$","h2","287",{"children":"21. Disponibilidad del servicio"}]
b8:["$","p","289",{"children":"La plataforma se ofrece en el estado técnico disponible en cada momento."}]
b9:["$","p","291",{"children":"No se garantiza disponibilidad permanente, ausencia de errores, continuidad indefinida, conservación ilimitada de información, compatibilidad con todos los dispositivos ni funcionamiento ininterrumpido."}]
ba:["$","p","293",{"children":"La plataforma podrá ser modificada, suspendida, interrumpida o discontinuada temporal o definitivamente por razones técnicas, organizativas, económicas, legales, de seguridad o de oportunidad científica."}]
bb:["$","p","295",{"children":"La persona usuaria es responsable de conservar copias externas de los prompts, materiales o información que considere relevantes."}]
bc:["$","h2","297",{"children":"22. Modificación de los términos de uso"}]
bd:["$","p","299",{"children":"La plataforma podrá modificar estos términos en cualquier momento para adaptarlos a cambios legales, técnicos, organizativos, científicos, funcionales o estratégicos."}]
be:["$","p","301",{"children":"La versión vigente será la publicada en la plataforma."}]
bf:["$","p","303",{"children":"Cuando los cambios sean relevantes, la plataforma podrá comunicarlo a las personas usuarias por los medios disponibles. El uso continuado de la plataforma tras la publicación de los cambios implicará la aceptación de la versión actualizada."}]
c0:["$","h2","305",{"children":"23. Legislación aplicable"}]
c1:["$","p","307",{"children":"Estos términos se regirán por la legislación española y europea que resulte aplicable, incluyendo la normativa sobre protección de datos, servicios de la sociedad de la información, propiedad intelectual, comercio electrónico y derechos digitales."}]
c2:["$","p","309",{"children":"Cualquier controversia se someterá a los órganos competentes conforme a la normativa aplicable, sin perjuicio de los derechos que puedan corresponder a personas consumidoras o usuarias cuando resulte legalmente aplicable."}]
c3:["$","h2","311",{"children":"24. Contacto"}]
c4:["$","p","313",{"children":"Para consultas sobre estos términos, incidencias, moderación, retirada de contenidos, ejercicio de derechos o comunicaciones relacionadas con la plataforma, podrá utilizarse el siguiente contacto:"}]
c5:["$","p","315",{"children":"Responsable de la plataforma: Andrés Blanco Di Matteo"}]
c6:["$","p","316",{"children":["Correo electrónico: ",["$","$L6",null,{"href":"mailto:giant@seimc.org","children":"giant@seimc.org"}],""]}]
