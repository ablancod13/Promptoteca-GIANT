c8:["$","p","318",{"children":"Fecha de última actualización: 30/06/2026"}]
c9:["$","h2","320",{"children":"25. Aceptación expresa"}]
ca:["$","p","322",{"children":"Al registrarse en la Promptoteca GIANT, la persona usuaria declara que:"}]
cb:["$","p","324",{"className":"legal-item","children":"a. Ha leído y comprendido estos términos de uso."}]
cc:["$","p","325",{"className":"legal-item","children":"b. Acepta cumplir el código de conducta de la plataforma."}]
cd:["$","p","326",{"className":"legal-item","children":"c. Acepta las normas de moderación, avisos, sanciones y posible suspensión o baneo."}]
ce:["$","p","327",{"className":"legal-item","children":"d. Acepta que sus puntuaciones, rankings o KPIs puedan ser modificados si incumple estos términos o si existen errores técnicos o conductas inapropiadas."}]
cf:["$","p","328",{"className":"legal-item","children":"e. Acepta que los prompts que publique se licencien bajo CC BY 4.0."}]
d0:["$","p","329",{"className":"legal-item","children":"f. Acepta no introducir datos de pacientes ni información identificativa."}]
d1:["$","p","330",{"className":"legal-item","children":"g. Acepta utilizar la plataforma bajo su propia responsabilidad."}]
